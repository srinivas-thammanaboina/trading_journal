# Trading Journal Configuration

# Path to the SPX Trader's SQLite journal database (read-only)
DB_PATH=/app/spx_trader/state/trading_journal.db

# Authentication
# Generate a password hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
PASSWORD_HASH=
ADMIN_SECRET=change-me-to-a-random-string
SESSION_SECRET=change-me-to-another-random-string

# Server
HOST=127.0.0.1
PORT=8001
DEBUG=false

# Rate limiting
LOGIN_RATE_LIMIT=5/minute

# Session expiry (hours)
SESSION_EXPIRY_HOURS=24
